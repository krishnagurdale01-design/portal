{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "login.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/login",
      "dest": "login.html"
    },
    {
      "src": "/admin",
      "dest": "admin.html"
    },
    {
      "src": "/login.html",
      "dest": "login.html"
    },
    {
      "src": "/admin.html",
      "dest": "admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
